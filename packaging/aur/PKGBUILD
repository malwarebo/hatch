# Maintainer: hatch authors <maintainers@hatch.sh>
pkgname=hatch-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="Capability-based isolation for AI tool servers"
arch=('x86_64' 'aarch64')
url="https://hatch.sh"
license=('Apache')
depends=('iptables' 'iproute2')
optdepends=('strace: hatch observe support'
            'landlock-tools: introspect landlock state')
provides=('hatch')
conflicts=('hatch')

source_x86_64=("https://github.com/malwarebo/hatch/releases/download/v${pkgver}/hatch-${pkgver}-x86_64-unknown-linux-gnu.tar.gz")
source_aarch64=("https://github.com/malwarebo/hatch/releases/download/v${pkgver}/hatch-${pkgver}-aarch64-unknown-linux-gnu.tar.gz")
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    install -Dm755 hatch          "${pkgdir}/usr/bin/hatch"
    install -Dm755 hatch-daemon   "${pkgdir}/usr/bin/hatch-daemon"
    install -Dm755 hatch-shim     "${pkgdir}/usr/bin/hatch-shim"
    install -Dm644 LICENSE        "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 README.md      "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
